<xsd:schema xmlns:xsd="http://www.w3.org/2001/XMLSchema">
	<!-- 基础数据类型定义 -->
	<!-- 字符串 -->
	<xsd:simpleType name="String">
		<xsd:annotation>
			<xsd:documentation>字符串</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string"/>
	</xsd:simpleType>
	<!-- 数字字符串 -->
	<xsd:simpleType name="Number">
		<xsd:annotation>
			<xsd:documentation>数字字符串</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:pattern value="[0-9]*"/>
		</xsd:restriction>
	</xsd:simpleType>
	<!-- 英文字符串 -->
	<xsd:simpleType name="Word">
		<xsd:annotation>
			<xsd:documentation>数字字符串</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:pattern value="[A-Za-z]*"/>
		</xsd:restriction>
	</xsd:simpleType>
	<!-- 标识字符串 -->
	<xsd:simpleType name="Token">
		<xsd:annotation>
			<xsd:documentation>标识字符串</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:pattern value="[A-Za-z0-9]*"/>
		</xsd:restriction>
	</xsd:simpleType>
	<!-- 文本 -->
	<xsd:simpleType name="Text">
		<xsd:annotation>
			<xsd:documentation>文本</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string"/>
	</xsd:simpleType>
	<!-- 金额 -->
	<xsd:simpleType name="Currency">
		<xsd:annotation>
			<xsd:documentation>金额</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:pattern value="\-?[1-9][0-9]{0,14}\.[0-9]{2}|\-?0\.[1-9][0-9]|\-?0\.[0-9][1-9]|0\.00"/>
		</xsd:restriction>
	</xsd:simpleType>
	<!-- 整数 -->
	<xsd:simpleType name="Integer">
		<xsd:annotation>
			<xsd:documentation>整数</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:integer"/>
	</xsd:simpleType>
	<!-- 实数 -->
	<xsd:simpleType name="Decimal">
		<xsd:annotation>
			<xsd:documentation>实数</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:double"/>
	</xsd:simpleType>
	<!-- 日期 -->
	<xsd:simpleType name="Date">
		<xsd:annotation>
			<xsd:documentation>日期</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:pattern value="[0-9]{4}(0[1-9]|1[0-2])([0-2][1-9]|[12][0-9]|3[01])"/>
		</xsd:restriction>
	</xsd:simpleType>
	<!-- 时间 -->
	<xsd:simpleType name="Time">
		<xsd:annotation>
			<xsd:documentation>时间</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:pattern value="[0-9]{2}[0-5][0-9][0-5][0-9]"/>
		</xsd:restriction>
	</xsd:simpleType>
	<!-- 日期时间 -->
	<xsd:simpleType name="DateTime">
		<xsd:annotation>
			<xsd:documentation>日期时间</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:pattern value="[0-9]{4}(0[1-9]|1[0-2])([0-2][1-9]|[12][0-9]|3[01])[0-9]{2}[0-5][0-9][0-5][0-9]"/>
		</xsd:restriction>
	</xsd:simpleType>
	<!-- 十六进制字符串 -->
	<xsd:simpleType name="Hex">
		<xsd:annotation>
			<xsd:documentation>十六进制字符串</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:pattern value="[0-9A-Fa-f]+"/>
		</xsd:restriction>
	</xsd:simpleType>
	<!-- Base64字符串 -->
	<xsd:simpleType name="Base64">
		<xsd:annotation>
			<xsd:documentation>Base64字符串</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string"/>
	</xsd:simpleType>
	<!-- 布尔值 -->
	<xsd:simpleType name="Boolean">
		<xsd:annotation>
			<xsd:documentation>布尔值</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:enumeration value="1"/>
			<xsd:enumeration value="0"/>
		</xsd:restriction>
	</xsd:simpleType>
	<!-- 简单数据类型定义 -->
	<!-- 1位数字字符串 -->
	<xsd:simpleType name="Number1">
