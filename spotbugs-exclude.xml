<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- 排除 Spring 配置类（很多是骨架） -->
    <Match>
        <Class name="~.*AutoConfiguration"/>
        <Bug pattern="UUF_UNUSED_FIELD"/>
    </Match>

    <!-- 排除测试类的某些检查 -->
    <Match>
        <Class name="~.*Test"/>
        <Bug pattern="DM_DEFAULT_ENCODING"/>
    </Match>

    <!-- Spring DI: 注入的可变对象引用是框架管理的单例，非安全风险 -->
    <Match>
        <Or>
            <Class name="com.puchain.fep.web.auth.jwt.JwtTokenProvider"/>
            <Class name="com.puchain.fep.web.auth.service.CaptchaService"/>
            <Class name="com.puchain.fep.web.auth.jwt.JwtAuthFilter"/>
            <Class name="com.puchain.fep.web.auth.jwt.JwtAuthEntryPoint"/>
            <Class name="com.puchain.fep.web.auth.service.AuthService"/>
            <Class name="com.puchain.fep.web.auth.service.LoginAttemptService"/>
            <Class name="com.puchain.fep.web.auth.service.SingleSignOnService"/>
            <Class name="com.puchain.fep.web.config.SecurityConfiguration"/>
            <Class name="com.puchain.fep.web.sysmgmt.role.service.SysRoleService"/>
            <Class name="com.puchain.fep.web.sysmgmt.role.controller.SysRoleController"/>
            <Class name="com.puchain.fep.web.sysmgmt.menu.service.SysMenuService"/>
            <Class name="com.puchain.fep.web.sysmgmt.menu.controller.SysMenuController"/>
            <Class name="com.puchain.fep.web.sysmgmt.user.service.SysUserService"/>
            <Class name="com.puchain.fep.web.sysmgmt.user.controller.SysUserController"/>
        </Or>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!-- LoginResponse: roleCodes 已通过 Collections.unmodifiableList 保护 -->
    <Match>
        <Class name="com.puchain.fep.web.auth.domain.LoginResponse"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>

    <!-- AuthController: 认证端点必须公开，SPRING_ENDPOINT 是预期行为 -->
    <Match>
        <Class name="com.puchain.fep.web.auth.controller.AuthController"/>
        <Bug pattern="SPRING_ENDPOINT"/>
    </Match>

    <!-- SysRoleController: 角色管理端点需认证（JWT），SPRING_ENDPOINT 是预期行为 -->
    <Match>
        <Class name="com.puchain.fep.web.sysmgmt.role.controller.SysRoleController"/>
        <Bug pattern="SPRING_ENDPOINT"/>
    </Match>

    <!-- RolePermissionAssignRequest: 请求 DTO 由 Jackson 反序列化填充，可变列表是预期行为 -->
    <Match>
        <Or>
            <Class name="com.puchain.fep.web.sysmgmt.role.dto.RolePermissionAssignRequest"/>
            <Class name="com.puchain.fep.web.sysmgmt.role.dto.RolePermissionAssignRequest$MenuPermission"/>
        </Or>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="EI_EXPOSE_REP2"/>
        </Or>
    </Match>

    <!-- SysRoleService/Controller: 角色编码/名称/状态均为受控枚举或数据库值，无 CRLF 注入风险 -->
    <Match>
        <Or>
            <Class name="com.puchain.fep.web.sysmgmt.role.service.SysRoleService"/>
            <Class name="com.puchain.fep.web.sysmgmt.role.controller.SysRoleController"/>
            <Class name="com.puchain.fep.web.sysmgmt.role.domain.SysRole"/>
        </Or>
        <Bug pattern="CRLF_INJECTION_LOGS"/>
    </Match>

    <!-- SysMenuService/SysUserService: 菜单编码/用户名/账号均为数据库值，无 CRLF 注入风险 -->
    <Match>
        <Or>
            <Class name="com.puchain.fep.web.sysmgmt.menu.service.SysMenuService"/>
            <Class name="com.puchain.fep.web.sysmgmt.menu.domain.SysMenu"/>
            <Class name="com.puchain.fep.web.sysmgmt.user.service.SysUserService"/>
            <Class name="com.puchain.fep.web.sysmgmt.user.domain.SysUser"/>
        </Or>
        <Bug pattern="CRLF_INJECTION_LOGS"/>
    </Match>

    <!-- SysMenuController: 菜单管理端点需认证（JWT），SPRING_ENDPOINT 是预期行为 -->
    <Match>
        <Class name="com.puchain.fep.web.sysmgmt.menu.controller.SysMenuController"/>
        <Bug pattern="SPRING_ENDPOINT"/>
    </Match>

    <!-- SysUserController: 用户管理端点需认证（JWT），SPRING_ENDPOINT 是预期行为 -->
    <Match>
        <Class name="com.puchain.fep.web.sysmgmt.user.controller.SysUserController"/>
        <Bug pattern="SPRING_ENDPOINT"/>
    </Match>

    <!-- UserCreateRequest/UserUpdateRequest/UserResponse: 请求/响应 DTO，可变列表是预期行为 -->
    <Match>
        <Or>
            <Class name="com.puchain.fep.web.sysmgmt.user.dto.UserCreateRequest"/>
            <Class name="com.puchain.fep.web.sysmgmt.user.dto.UserUpdateRequest"/>
            <Class name="com.puchain.fep.web.sysmgmt.user.dto.UserResponse"/>
            <Class name="com.puchain.fep.web.sysmgmt.menu.dto.MenuTreeNode"/>
        </Or>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="EI_EXPOSE_REP2"/>
        </Or>
    </Match>

    <!-- JwtTokenProvider 是 Spring 单例，构造器异常在启动时快速失败是期望行为 -->
    <Match>
        <Class name="com.puchain.fep.web.auth.jwt.JwtTokenProvider"/>
        <Bug pattern="CT_CONSTRUCTOR_THROW"/>
    </Match>

    <!-- CaptchaService: 验证码仅使用 ASCII 字母数字，equalsIgnoreCase 无 Unicode 风险 -->
    <Match>
        <Class name="com.puchain.fep.web.auth.service.CaptchaService"/>
        <Bug pattern="IMPROPER_UNICODE"/>
    </Match>

    <!-- MockSignService 固定签名是 mock，非硬编码密钥 -->
    <Match>
        <Class name="com.puchain.fep.security.mock.MockSignService"/>
        <Or>
            <Bug pattern="DMI_CONSTANT_DB_PASSWORD"/>
            <Bug pattern="HARD_CODE_PASSWORD"/>
        </Or>
    </Match>
</FindBugsFilter>
